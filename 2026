    if (i > 0 && p.scores?.total !== sorted[i-1].scores?.total) rank = i + 1;
    const s = p.scores || {};
    return [rank, p.name, s.r1||0, s.r2||0, s.r3||0, s.cup||0, s.series||0, s.players||0, s.total||0, p.paid?'Yes':'No'];
  });

  const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
  const blob = new Blob([csv], { type:'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `nhl-bracket-2025.csv`;
  a.click();
}

