<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NHL Bracket Tournament</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ice: #e8f4f8;
    --ice-dim: #b8d4de;
    --rink: #0a1628;
    --rink-mid: #0f2040;
    --rink-light: #162d52;
    --red: #c8102e;
    --red-light: #e8213f;
    --gold: #ffb81c;
    --gold-dim: #c48a00;
    --west: #1a6fc4;
    --east: #c8102e;
    --text: #e8f4f8;
    --text-dim: #7a9db5;
    --border: rgba(232,244,248,0.12);
    --glass: rgba(15,32,64,0.7);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Barlow', sans-serif;
    background: var(--rink);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── ICE TEXTURE BACKGROUND ── */
  body::before {
    content:'';
    position:fixed; inset:0; z-index:0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(232,244,248,0.015) 60px, rgba(232,244,248,0.015) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(232,244,248,0.01) 80px, rgba(232,244,248,0.01) 81px),
      radial-gradient(ellipse at 20% 50%, rgba(26,111,196,0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(200,16,46,0.06) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 80%, rgba(26,111,196,0.05) 0%, transparent 50%),
      linear-gradient(180deg, #060e1e 0%, #0a1628 40%, #0d1e38 100%);
    pointer-events:none;
  }

  /* ── CENTER ICE CIRCLE ── */
  body::after {
    content:'';
    position:fixed;
    top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:600px; height:600px;
    border-radius:50%;
    border: 2px solid rgba(232,244,248,0.04);
    pointer-events:none;
    z-index:0;
  }

  .page { position:relative; z-index:1; }

  /* ── HEADER ── */
  header {
    text-align:center;
    padding: 56px 24px 40px;
    position:relative;
  }

  .header-year {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 6px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  header h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(42px, 8vw, 84px);
    font-weight: 900;
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -1px;
    color: var(--ice);
  }

  header h1 span {
    color: var(--gold);
    display: block;
  }

  .header-sub {
    margin-top: 16px;
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .header-line {
    width: 60px; height: 3px;
    background: var(--gold);
    margin: 24px auto 0;
  }

  /* ── NAV TABS ── */
  .nav {
    display: flex;
    justify-content: center;
    gap: 4px;
    padding: 0 24px 40px;
    flex-wrap: wrap;
  }

  .nav-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 28px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
  }

  .nav-btn:hover { border-color: var(--ice-dim); color: var(--ice); }
  .nav-btn.active { background: var(--gold); border-color: var(--gold); color: var(--rink); }

  /* ── SECTIONS ── */
  .section { display:none; padding: 0 24px 80px; max-width: 1400px; margin: 0 auto; }
  .section.active { display:block; }

  /* ── SECTION HEADER ── */
  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .section-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--ice);
    margin-bottom: 32px;
    line-height: 1;
  }

  /* ── CARDS ── */
  .card {
    background: var(--glass);
    border: 1px solid var(--border);
    border-radius: 4px;
    backdrop-filter: blur(12px);
    padding: 32px;
  }

  /* ══════════════════════════════════
     SUBMIT BRACKET
  ══════════════════════════════════ */
  .submit-intro {
    max-width: 640px;
    margin-bottom: 40px;
  }

  .submit-intro p {
    font-size: 15px;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* Name input */
  .name-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 40px;
    max-width: 600px;
  }

  .field-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
    display: block;
  }

  .field-input {
    width: 100%;
    background: rgba(232,244,248,0.05);
    border: 1.5px solid var(--border);
    border-radius: 2px;
    padding: 12px 16px;
    font-family: 'Barlow', sans-serif;
    font-size: 15px;
    color: var(--ice);
    outline: none;
    transition: border-color 0.2s;
  }

  .field-input:focus { border-color: var(--gold); }
  .field-input::placeholder { color: var(--text-dim); }

  /* ── BRACKET VISUAL ── */
  .bracket-layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    margin-bottom: 40px;
  }

  .conference-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-align: center;
    padding: 14px;
    margin-bottom: 16px;
    border-radius: 2px;
  }

  .conf-west { background: var(--west); color: white; }
  .conf-east { background: var(--east); color: white; }
  .conf-cup { background: var(--gold); color: var(--rink); }

  .bracket-side {
    display: flex;
    flex-direction: column;
  }

  .rounds-container {
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  .round-col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .round-header {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-dim);
    text-align: center;
    padding: 8px 4px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }

  .round-header span {
    color: var(--gold);
    font-size: 9px;
    display: block;
    margin-top: 2px;
  }

  /* ── SERIES CARD ── */
  .series-slot {
    margin: 4px;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .series-card {
    background: rgba(232,244,248,0.04);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 10px;
    width: 100%;
    transition: border-color 0.2s;
  }

  .series-card.complete { border-color: rgba(255,184,28,0.4); }

  .team-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.15s;
    border: 1.5px solid transparent;
    margin-bottom: 4px;
  }

  .team-option:last-child { margin-bottom: 0; }

  .team-option:hover { background: rgba(232,244,248,0.07); }

  .team-option.selected {
    background: rgba(255,184,28,0.12);
    border-color: var(--gold);
  }

  .team-radio {
    width: 14px; height: 14px;
    border: 1.5px solid var(--text-dim);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.15s;
  }

  .team-option.selected .team-radio {
    border-color: var(--gold);
    background: var(--gold);
  }

  .team-option.selected .team-radio::after {
    content:'';
    position:absolute;
    top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:5px; height:5px;
    background: var(--rink);
    border-radius:50%;
  }

  .team-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--ice);
    flex: 1;
  }

  .series-divider {
    height: 1px;
    background: var(--border);
    margin: 6px 0;
  }

  .games-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 6px;
    padding-top: 6px;
    border-top: 1px solid var(--border);
  }

  .games-label {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .games-options {
    display: flex;
    gap: 4px;
  }

  .game-btn {
    width: 26px; height: 26px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-dim);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .game-btn:hover { border-color: var(--ice-dim); color: var(--ice); }
  .game-btn.selected { background: var(--gold); border-color: var(--gold); color: var(--rink); }

  /* CUP CENTER */
  .cup-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    min-width: 200px;
  }

  .cup-trophy {
    font-size: 48px;
    margin-bottom: 12px;
    filter: drop-shadow(0 0 20px rgba(255,184,28,0.5));
  }

  .cup-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    margin-bottom: 16px;
  }

  .cup-matchup {
    background: rgba(255,184,28,0.08);
    border: 1.5px solid rgba(255,184,28,0.3);
    border-radius: 4px;
    padding: 16px;
    width: 100%;
    text-align: center;
  }

  .cup-vs {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin: 6px 0;
  }

  .cup-team {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--ice-dim);
    min-height: 22px;
  }

  .cup-team.picked { color: var(--gold); }

  /* ── PLAYER PICKS ── */
  .player-picks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }

  .player-pick-card {
    background: rgba(232,244,248,0.04);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 16px;
  }

  .pick-category {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .pick-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 8px;
    border-radius: 2px;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: all 0.15s;
    margin-bottom: 4px;
  }

  .pick-option:hover { background: rgba(232,244,248,0.05); }
  .pick-option.selected { background: rgba(255,184,28,0.1); border-color: rgba(255,184,28,0.4); }

  .pick-radio {
    width: 12px; height: 12px;
    border: 1.5px solid var(--text-dim);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .pick-option.selected .pick-radio {
    border-color: var(--gold);
    background: var(--gold);
  }

  .pick-option.selected .pick-radio::after {
    content:'';
    position:absolute;
    top:50%; left:50%;
    transform:translate(-50%,-50%);
    width:4px; height:4px;
    background: var(--rink);
    border-radius:50%;
  }

  .pick-player-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ice);
  }

  .pick-player-team {
    font-size: 11px;
    color: var(--text-dim);
    margin-left: auto;
    font-family: 'Barlow Condensed', sans-serif;
    letter-spacing: 1px;
  }

  /* ── SUBMIT BTN ── */
  .submit-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 16px 40px;
    background: var(--gold);
    color: var(--rink);
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover { background: #ffc840; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(255,184,28,0.25); }
  .btn-primary:active { transform: translateY(0); }
  .btn-primary:disabled { background: var(--text-dim); cursor: not-allowed; transform: none; box-shadow: none; }

  .submit-note {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .submit-success {
    display: none;
    background: rgba(50,200,100,0.1);
    border: 1.5px solid rgba(50,200,100,0.3);
    border-radius: 3px;
    padding: 20px 28px;
    margin-top: 24px;
  }

  .submit-success.show { display: block; }

  .submit-success h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    color: #64e096;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 6px;
  }

  .submit-success p { font-size: 14px; color: var(--text-dim); }

  /* ══════════════════════════════════
     LEADERBOARD
  ══════════════════════════════════ */
  .pot-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .pot-card {
    background: rgba(232,244,248,0.04);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 20px 16px;
    text-align: center;
  }

  .pot-card-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .pot-card-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: var(--gold);
  }

  .pot-card.gold { border-color: rgba(255,184,28,0.4); background: rgba(255,184,28,0.08); }
  .pot-card.silver { border-color: rgba(200,200,220,0.3); }
  .pot-card.bronze { border-color: rgba(180,120,60,0.3); }

  /* Leaderboard table */
  .lb-table { width: 100%; border-collapse: collapse; }

  .lb-table th {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .lb-table th.right { text-align: right; }

  .lb-table td {
    padding: 13px 16px;
    font-size: 14px;
    color: var(--ice);
    border-bottom: 1px solid rgba(232,244,248,0.05);
    vertical-align: middle;
  }

  .lb-table td.right { text-align: right; }

  .lb-table tr:hover td { background: rgba(232,244,248,0.03); cursor: pointer; }

  .lb-rank {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 900;
    color: var(--text-dim);
    width: 40px;
  }

  .lb-rank.r1 { color: var(--gold); }
  .lb-rank.r2 { color: #b0b8c8; }
  .lb-rank.r3 { color: #c8834a; }

  .lb-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .lb-points {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--gold);
  }

  .lb-pts-label {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  .paid-badge {
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    background: rgba(50,200,100,0.15);
    color: #64e096;
    border: 1px solid rgba(50,200,100,0.25);
  }

  .unpaid-badge {
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    background: rgba(200,16,46,0.15);
    color: #e86070;
    border: 1px solid rgba(200,16,46,0.25);
  }

  .mini-bar {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  .mini-seg {
    height: 4px;
    border-radius: 1px;
    background: var(--rink-light);
    flex: 1;
  }

  .mini-seg.r1 { background: #1a6fc4; }
  .mini-seg.r2 { background: #2080d4; }
  .mini-seg.r3 { background: #4a9ee0; }
  .mini-seg.rc { background: var(--gold); }
  .mini-seg.rs { background: #7ab0d0; }
  .mini-seg.rp { background: #5090b8; }

  /* ── BRACKET VIEWER ── */
  .viewer-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
    margin-bottom: 32px;
  }

  .viewer-chip {
    background: rgba(232,244,248,0.04);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 12px 16px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .viewer-chip:hover { border-color: var(--gold); background: rgba(255,184,28,0.05); }

  .viewer-chip-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 700;
  }

  .viewer-chip-pts {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--gold);
  }

  /* ── ADMIN ── */
  .admin-gate {
    max-width: 400px;
    margin: 0 auto;
    text-align: center;
    padding: 60px 0;
  }

  .admin-gate h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 24px;
    color: var(--ice);
  }

  .admin-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  .admin-card {
    background: rgba(232,244,248,0.04);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 20px;
  }

  .admin-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .result-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .result-label {
    font-size: 13px;
    color: var(--text-dim);
    width: 180px;
    flex-shrink: 0;
  }

  .result-winner {
    flex: 1;
    background: rgba(232,244,248,0.05);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 6px 10px;
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    color: var(--ice);
    outline: none;
    min-width: 120px;
  }

  .result-winner:focus { border-color: var(--gold); }

  select.result-winner option { background: var(--rink-mid); }

  .result-games {
    width: 60px;
    background: rgba(232,244,248,0.05);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 6px 10px;
    font-family: 'Barlow', sans-serif;
    font-size: 13px;
    color: var(--ice);
    outline: none;
    text-align: center;
  }

