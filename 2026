function submitBracket() {
  const name = document.getElementById('participantName').value.trim();
  if (!name) { alert('Please enter your name.'); return; }

  if (!state.submissionsOpen) {
    alert('Submissions are currently closed. Contact the commissioner.');
    return;
  }

  // Check if name already submitted
  const existing = state.participants.find(p => p.name.toLowerCase() === name.toLowerCase());
  if (existing) {
    alert(`A bracket for "${name}" has already been submitted. Contact the commissioner if you need to make changes.`);
    return;
  }

  const participant = {
    name,
    email: document.getElementById('participantEmail').value.trim(),
    picks: JSON.parse(JSON.stringify(currentPicks)),
    playerPicks: JSON.parse(JSON.stringify(currentPlayerPicks)),
    submitted: new Date().toISOString(),
    paid: false,
    scores: { r1:0, r2:0, r3:0, cup:0, series:0, players:0, total:0 }
  };

  state.participants.push(participant);
  setState(state);
  recalculateAllScores();

  document.getElementById('submitSuccess').classList.add('show');
  document.getElementById('submitBtn').disabled = true;

  // Reset form for next person
  currentPicks = {};
  currentPlayerPicks = {};
}

// ════════════════════════════════════════
// SCORING ENGINE
// ════════════════════════════════════════

function recalculateAllScores() {
  state.participants.forEach(p => {
    p.scores = calculateScores(p);
  });
  setState(state);
}

function calculateScores(participant) {
  const scores = { r1:0, r2:0, r3:0, cup:0, series:0, players:0, total:0 };
  const picks = participant.picks || {};
  const pPicks = participant.playerPicks || {};

  // Series picks
  ['west','east'].forEach(conf => {
    ['r1','r2','r3'].forEach(round => {
      const matchups = getMatchups(conf, round, state.results); // use actual results for matchup cascade
      matchups.forEach((_, idx) => {
        const sid = buildSeriesId(conf, round, idx);
        const result = state.results[sid];
        const pick = picks[sid];
        if (result && result.winner && pick) {
          if (pick.winner === result.winner) {
            scores[round] += ROUND_PTS[round];
          }
          if (pick.games === result.games) {
            scores.series += GAMES_PT;
          }
        }
      });
    });
  });

  // Cup
  const cupResult = state.results['cup'];
  const cupPick = picks['cup'];
  if (cupResult && cupResult.winner && cupPick) {
    if (cupPick.winner === cupResult.winner) scores.cup += ROUND_PTS.cup;
    if (cupPick.games === cupResult.games) scores.series += GAMES_PT;
  }

  // Player picks — admin sets these in results as playerResults: {key: winnerName}
  const playerResults = state.results['_players'] || {};
  PLAYER_PICKS.forEach(cat => {
    if (playerResults[cat.key] && pPicks[cat.key] === playerResults[cat.key]) {
      scores.players += PLAYER_PT;
    }
  });

  scores.total = scores.r1 + scores.r2 + scores.r3 + scores.cup + scores.series + scores.players;
  return scores;
}

