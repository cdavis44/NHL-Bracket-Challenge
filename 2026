<script>
// ════════════════════════════════════════
// DATA — Edit these before each tournament
// ════════════════════════════════════════

const TOURNAMENT_YEAR = 2025;
const BUY_IN = 10;
const ADMIN_PASSWORD = '2026DaveBrack'; // CHANGE THIS

// 2025 Playoff teams — edit each year
const WEST_R1 = [
  { home: 'Winnipeg Jets',      away: 'St. Louis Blues' },
  { home: 'Dallas Stars',       away: 'Colorado Avalanche' },
  { home: 'Vegas Golden Knights', away: 'Minnesota Wild' },
  { home: 'LA Kings',           away: 'Edmonton Oilers' },
];

const EAST_R1 = [
  { home: 'Toronto Maple Leafs', away: 'Ottawa Senators' },
  { home: 'Tampa Bay Lightning', away: 'Florida Panthers' },
  { home: 'Washington Capitals', away: 'Montreal Canadiens' },
  { home: 'Carolina Hurricanes', away: 'New Jersey Devils' },
];

const PLAYER_PICKS = [
  {
    category: 'Goals Leader',
    key: 'goals',
    pts: 1,
    options: [
      { name: 'William Nylander', team: 'TOR' },
      { name: 'Alex Ovechkin',    team: 'WSH' },
      { name: 'Leon Draisaitl',   team: 'EDM' },
    ]
  },
  {
    category: 'Assists Leader',
    key: 'assists',
    pts: 1,
    options: [
      { name: 'Connor McDavid',  team: 'EDM' },
      { name: 'Jack Eichel',     team: 'VGK' },
      { name: 'Cale Makar',      team: 'COL' },
    ]
  },
  {
    category: 'Save % Leader',
    key: 'savepcт',
    pts: 1,
    options: [
      { name: 'Connor Hellebuyck', team: 'WPJ' },
      { name: 'Anthony Stolarz',   team: 'TOR' },
      { name: 'Jake Oettinger',    team: 'DAL' },
    ]
  },
  {
    category: 'Penalty Min Leader',
    key: 'pim',
    pts: 1,
    options: [
      { name: 'Tom Wilson',      team: 'WSH' },
      { name: 'A.J. Greer',      team: 'FLA' },
      { name: 'Brady Tkatchuk',  team: 'OTT' },
    ]
  },
  {
    category: 'Highest Overall',
    key: 'overall',
    pts: 1,
    options: [
      { name: 'Mitch Marner',    team: 'TOR' },
      { name: 'Nathan MacKinnon', team: 'COL' },
      { name: 'Nikita Kucherov', team: 'TBL' },
    ]
  },
];

// SCORING
const ROUND_PTS = { r1:1, r2:2, r3:3, cup:5 };
const GAMES_PT = 1;
const PLAYER_PT = 1;

// ════════════════════════════════════════
// STATE (persisted to localStorage)
// ════════════════════════════════════════

function getState() {
  try {
    return JSON.parse(localStorage.getItem('nhl_bracket_2025') || '{}');
  } catch(e) { return {}; }
}

function setState(s) {
  localStorage.setItem('nhl_bracket_2025', JSON.stringify(s));
}

function getDefaults() {
  return {
    participants: [],      // [{name, email, picks, playerPicks, submitted, paid, scores}]
    results: {},           // {seriesId: {winner, games}}
    submissionsOpen: true,
  };
}

let state = { ...getDefaults(), ...getState() };

// Current bracket being built
let currentPicks = {};    // {seriesId: {winner, games}}
let currentPlayerPicks = {}; // {key: playerName}

// ════════════════════════════════════════
// BRACKET STRUCTURE HELPERS
// ════════════════════════════════════════

// seriesId format: "west_r1_0", "west_r2_0", "cup"
// Rounds: r1(4 series each side), r2(2), r3(1), cup(1)

function buildSeriesId(conf, round, idx) {
  return `${conf}_${round}_${idx}`;
}

// Get winners advancing from results or picks
function getWinner(seriesId, picks) {
  const res = state.results[seriesId];
  if (res && res.winner) return res.winner;
  if (picks && picks[seriesId]) return picks[seriesId].winner;
  return null;
}

// Build round matchups dynamically based on previous round picks
function getMatchups(conf, round, picks) {
  if (round === 'r1') {
    return conf === 'west' ? WEST_R1 : EAST_R1;
  }
  const prev = prevRound(round);
  const prevMatchups = getMatchups(conf, prev, picks);
  const matchups = [];
  for (let i = 0; i < prevMatchups.length; i += 2) {
    const w1 = getWinner(buildSeriesId(conf, prev, i), picks) || `Pick ${i+1} Winner`;
    const w2 = getWinner(buildSeriesId(conf, prev, i+1), picks) || `Pick ${i+2} Winner`;
    matchups.push({ home: w1, away: w2 });
  }
  return matchups;
}

function prevRound(r) {
  return { r2:'r1', r3:'r2', cup:'r3' }[r] || null;
}

function roundLabel(r) {
  return { r1:'Round 1', r2:'Round 2', r3:'Conf. Final', cup:'Cup Final' }[r];
}

function roundPts(r) {
  return ROUND_PTS[r];
}

// ════════════════════════════════════════
// BRACKET RENDER — SUBMIT FORM
// ════════════════════════════════════════

const ROUNDS = ['r1', 'r2', 'r3'];

function renderBracket() {
  renderConference('west', document.getElementById('westRounds'));
  renderConference('east', document.getElementById('eastRounds'));
  renderCupCenter();
  updateProgress();
}

function renderConference(conf, container) {
  container.innerHTML = '';
  ROUNDS.forEach(round => {
    const col = document.createElement('div');
    col.className = 'round-col';
    col.innerHTML = `<div class="round-header">${roundLabel(round)}<span>${roundPts(round)} pt${roundPts(round)>1?'s':''}</span></div>`;
    const matchups = getMatchups(conf, round, currentPicks);
    const slots = document.createElement('div');
    slots.style.cssText = 'display:flex;flex-direction:column;flex:1;';
    matchups.forEach((m, idx) => {
      const sid = buildSeriesId(conf, round, idx);
      const slot = document.createElement('div');
      slot.className = 'series-slot';
      slot.style.flex = '1';
      slot.innerHTML = renderSeriesCard(sid, m.home, m.away);
      slots.appendChild(slot);
    });
    col.appendChild(slots);
    container.appendChild(col);
  });
}

function renderSeriesCard(sid, home, away) {
  const pick = currentPicks[sid] || {};
  const winnerPicked = pick.winner;
  const gamesPicked = pick.games;
  const complete = winnerPicked && gamesPicked;

  const homeSelected = winnerPicked === home ? 'selected' : '';
  const awaySelected = winnerPicked === away ? 'selected' : '';

  const gamesOpts = [4,5,6,7].map(g =>
    `<button class="game-btn ${gamesPicked===g?'selected':''}" onclick="pickGames('${sid}', ${g})">${g}</button>`
  ).join('');

  return `
    <div class="series-card ${complete?'complete':''}" id="card_${sid}">
