function updateProgress() {
  // Total series: 4+2+1 west + 4+2+1 east + 1 cup = 15
  const allSeries = [];
  ['west','east'].forEach(conf => {
    ROUNDS.forEach(round => {
      const matchups = getMatchups(conf, round, currentPicks);
      matchups.forEach((_, idx) => allSeries.push(buildSeriesId(conf, round, idx)));
    });
  });
  allSeries.push('cup');

  const picked = allSeries.filter(sid => currentPicks[sid] && currentPicks[sid].winner && currentPicks[sid].games).length;
  const total = 15;
  document.getElementById('progressText').textContent = `${picked} of ${total} series picked`;
  document.getElementById('progressBar').style.width = `${(picked/total)*100}%`;
}

